generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  comments    Comment[]
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  password String
  comments Comment[]
}

model Comment {
  id        Int     @id @default(autoincrement())
  content   String
  productId Int
  userId    Int
  product   Product @relation(fields: [productId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
}


