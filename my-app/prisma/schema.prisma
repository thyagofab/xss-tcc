generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  comments    Comment[]
}

model Comment {
  id        Int     @id @default(autoincrement())
  content   String
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}
